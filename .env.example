# 量化交易系统环境变量
# 请将此文件重命名为 .env 并填入实际值
# 注意：此文件已添加到 .gitignore，不会提交到版本控制

# ==================== CTP 接口配置 ====================
# 获取 CTP 账号信息：联系期货公司或登录交易软件
CTP_PASSWORD=""
CTP_BROKERID="9999"
CTP_USERID=""
CTP_APPID=""
CTP_AUTHCODE=""

# ==================== 交易接口配置 ====================
# XTP 接口
XTP_PASSWORD=""
XTP_BROKERID=""
XTP_USERID=""

# 华鑫奇点接口
WINCHIN_PASSWORD=""
WINCHIN_BROKERID=""
WINCHIN_USERID=""

# ==================== 邮件配置 ====================
EMAIL_SERVER=""
EMAIL_PORT=25
EMAIL_USERNAME=""
EMAIL_PASSWORD=""
EMAIL_SENDER=""
EMAIL_RECEIVER_1=""
EMAIL_RECEIVER_2=""

# ==================== 数据库配置 ====================
DATABASE_TYPE="sqlite"
DATABASE_PATH="./data.db"
MYSQL_HOST="localhost"
MYSQL_PORT=3306
MYSQL_USER=""
MYSQL_PASSWORD=""
MYSQL_DATABASE=""

# ==================== 日志配置 ====================
LOG_LEVEL="INFO"
LOG_FILE_PATH="./logs"
LOG_FILE_SIZE=10485760
LOG_MAX_FILES=10

# ==================== 风险管理配置 ====================
RISK_MAX_POSITION=100
RISK_MAX_DAILY_LOSS=10000
RISK_MAX_DRAWDOWN=0.1
RISK_MAX_RISK_PER_TRADE=0.02

# ==================== 策略配置 ====================
STRATEGY_BOLL_PERIOD=20
STRATEGY_BOLL_DEV=1
STRATEGY_ATR_PERIOD=14
STRATEGY_ATR_MULTIPLIER=2

# ==================== 回测配置 ====================
BACKTESTING_START_DATE="20230101"
BACKTESTING_END_DATE="20231231"
BACKTESTING_INITIAL_CAPITAL=1000000

# ==================== 其他配置 ====================
TRADER_NAME=""
TRADER_UI="qt"
DEBUG_MODE=false

# 提示：
# 1. 复制此文件为 .env 并填入实际值
# 2. 在代码中使用 os.getenv() 读取环境变量
# 3. 切勿将包含真实密码的文件提交到 Git
